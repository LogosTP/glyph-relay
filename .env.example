#
# glyph-relay environment TEMPLATE. Copy to the EnvironmentFile referenced by
# ops/glyph-relay.service (e.g. /etc/glyph-relay/relay.env), fill in values, and keep
# it root-owned 0600 — NEVER commit a filled-in copy. Lines marked "secret" must live
# in the env file only (never a CLI flag, so they stay out of the process listing).
# Empty = use the in-code default (see glyph_relay/config.py). The relay reads these
# via config.build_relay(mode, env).

# --- Mode + bind ------------------------------------------------------------
RELAY_MODE=            # "hosted" or "selfhost" (CLI --mode overrides; default selfhost)
RELAY_HOST=            # bind address (default 127.0.0.1 — keep loopback; tunnel fronts it)
RELAY_PORT=            # bind port (default 8765)

# --- Hosted auth: broker-token signing (shared with glyph-hosted) -----------
SHARED_HMAC_KID=       # key id, e.g. "v1"; rotate by adding the new kid, keeping the old
SHARED_HMAC_KEY=       # secret — broker-token HMAC key; MUST byte-match glyph-hosted's
RELAY_ADMIN_SECRET=    # secret — X-Relay-Admin value for /admin/revoke|purge

# --- Durable history --------------------------------------------------------
HISTORY_DB=            # path to the SQLite history db (e.g. /var/lib/glyph-relay/history.db; encrypted volume)
HISTORY_MAX_ROWS_PER_SESSION=   # per-(tenant,session) durable-history ring bound (default 20000)

# --- SSRF target policy (hosted; one relay serves many MUDs) ----------------
RELAY_TARGET_ALLOWLIST=         # path to a host[:port]-per-line allowlist file (the server directory)
RELAY_TARGET_PORTS=             # allowed port window "lo-hi", e.g. 1024-65535 (default: any)

# --- MUD target (self-host single target; hosted uses per-request target) ----
MUD_HOST=              # MUD hostname (self-host default 127.0.0.1; hosted default "-")
MUD_PORT=              # MUD port (self-host default 4000; hosted default 0)
MUD_TLS=              # connect to the MUD over TLS: 1/true/yes/on (hosted default on, self-host off)

# --- Quotas + lifecycle -----------------------------------------------------
MAX_SESSIONS=          # global concurrent-session cap (hosted default 200, self-host 20)
MAX_PER_TENANT=        # per-tenant concurrent-session cap (hosted default 5)
IDLE_TTL=              # idle-session reap seconds (default 1800)

# --- Rate limits ------------------------------------------------------------
SESSION_RATE=          # POST /session attempts per window (0/empty disables)
SESSION_WINDOW=        # /session rate-limit window seconds (default 60)
INGEST_RATE=           # per-tenant POST /ingest reqs per window (default 60; 0 disables)
INGEST_WINDOW=         # /ingest rate-limit window seconds (default 60)

# --- Push-trigger notify (hosted; relay -> co-located glyph-hosted sender) ----
RELAY_NOTIFY_URL=      # hosted notify endpoint, e.g. http://127.0.0.1:8080/v1/push/notify (loopback)
RELAY_NOTIFY_SECRET=   # secret — env only; X-Relay-Notify value; MUST byte-match glyph-hosted's
RELAY_NOTIFY_RATE=     # per-(tenant,session) outbound notify cap per window (default 120; 0 disables)
RELAY_NOTIFY_WINDOW=   # notify rate-limit window seconds (default 60)

# --- Self-host-only enrollment (ignored in hosted mode) ---------------------
GLYPH_ENROLL_SECRET=   # secret — optional global X-Relay-Enroll shared secret (empty = open self-host)
RELAY_ENROLL_DB=       # path to the per-user enrollment registry db (#140; supersedes the shared secret)
MUD_CA_FILE=           # optional CA bundle for the self-host MUD's TLS cert
